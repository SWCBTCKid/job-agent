# Copy this to .env and fill in your keys. Never commit .env.

ANTHROPIC_API_KEY=sk-ant-...
VOYAGE_API_KEY=pa-...          # optional — for Voyage embeddings
OPENAI_API_KEY=sk-...          # optional — for OpenAI embeddings
TELEGRAM_BOT_TOKEN=...         # optional — for notifications
TELEGRAM_CHAT_ID=...           # optional — for notifications
THEIRSTACK_API_KEY=...         # optional
SERPAPI_KEY=...                # optional

# Tuning (defaults shown)
JOB_AGENT_SALARY_FLOOR=150000
JOB_AGENT_STAGE1_THRESHOLD=0.35
JOB_AGENT_TOP_N_OUTPUT=100
JOB_AGENT_CLAUDE_MODEL=claude-sonnet-4-6
JOB_AGENT_HAIKU_MODEL=claude-haiku-4-5-20251001
